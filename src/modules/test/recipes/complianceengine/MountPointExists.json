[
  {
    "Action": "LoadModule",
    "Module": "complianceengine.so"
  },
// This test assumes, that /proc is mounted and /usr/bin is not - should be safe everywhere.

  {
    "ObjectType": "Desired",
    "ComponentName": "ComplianceEngine",
    "ObjectName": "procedureTest",
    "Payload": {
      "audit": {
        "MountPointExists": {
          "mountPoint": "/proc"
        }
      },
      "parameters": {
      }
    }
  },
  {
    "ObjectType": "Reported",
    "ComponentName": "ComplianceEngine",
    "ObjectName": "auditTest",
    "Payload": "PASS{ MountPointExists: Mount point \/proc is mounted } == TRUE"
  },

  {
    "ObjectType": "Desired",
    "ComponentName": "ComplianceEngine",
    "ObjectName": "procedureTest",
    "Payload": {
      "audit": {
        "MountPointExists": {
          "mountPoint": "/usr/bin"
        }
      },
      "parameters": {
      }
    }
  },
  {
    "ObjectType": "Reported",
    "ComponentName": "ComplianceEngine",
    "ObjectName": "auditTest",
    "Payload": "{ MountPointExists: Mount point \/usr\/bin is not mounted } == FALSE"
  },

  {
    "Action": "UnloadModule"
  }
]
