{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "audit": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "EnsureSshdOption"
          ],
          "additionalProperties": false,
          "properties": {
            "EnsureSshdOption": {
              "type": "object",
              "required": [
                "option",
                "value"
              ],
              "additionalProperties": false,
              "properties": {
                "option": {
                  "type": "string",
                  "description": "Name of the SSH daemon option"
                },
                "value": {
                  "type": "string",
                  "description": "One of Regex, list of regexes, string, integer threshold the option value is evaluated against"
                },
                "op": {
                  "type": "string",
                  "description": "(match|not_match|lt|le|gt|ge) optional, defaults to regex::^(regex|match|not_match|lt|le|gt|ge)$"
                },
                "mode": {
                  "type": "string",
                  "description": "(regular|all_matches) optional, defaults to regular::^(regular|all_matches)"
                }
              }
            }
          }
        }
      ]
    },
    "remediation": {
      "anyOf": []
    }
  }
}
