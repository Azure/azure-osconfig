{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "audit": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "SystemdParameter"
          ],
          "additionalProperties": false,
          "properties": {
            "SystemdParameter": {
              "type": "object",
              "required": [
                "parameter"
              ],
              "additionalProperties": false,
              "properties": {
                "parameter": {
                  "type": "string",
                  "description": "Parameter name"
                },
                "valueRegex": {
                  "type": "string",
                  "description": "Regex for the value, can be used instead of operator + value comparison"
                },
                "op": {
                  "type": "string",
                  "description": "Operator for the value"
                },
                "value": {
                  "type": "string",
                  "description": "Value to compare with"
                },
                "file": {
                  "type": "string",
                  "description": "Config filename"
                },
                "block": {
                  "type": "string",
                  "description": "Block in which the parameter is expected to be (e.g. [Unit], [Service], etc.)"
                },
                "dir": {
                  "type": "string",
                  "description": "Directory to search for config files"
                }
              }
            }
          }
        }
      ]
    },
    "remediation": {
      "anyOf": []
    }
  }
}
